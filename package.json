{
  "name": "cryptolab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Learn cryptography by watching real algorithms transform real input, step by step.",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite-react-ssg dev",
    "build": "tsc -b && vite-react-ssg build && node scripts/generate-sitemap.mjs",
    "preview": "vite preview --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-react-ssg": "^0.9.2",
    "vitest": "^3.2.0"
  }
}
